{
  "name": "@mtldev514/actions",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable GitHub Actions workflows and TypeScript actions",
  "scripts": {
    "build": "npm run build:deploy-vercel && npm run build:apply-migration && npm run build:publish-npm",
    "build:deploy-vercel": "ncc build src/deploy-vercel.ts -o deploy-vercel/dist --license licenses.txt",
    "build:apply-migration": "ncc build src/apply-migration.ts -o apply-migration/dist --license licenses.txt",
    "build:publish-npm": "ncc build src/publish-npm.ts -o publish-npm/dist --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.7.0"
  }
}
